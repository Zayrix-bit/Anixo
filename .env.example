###############################################################################
#                    🎬 ANIXO — ENVIRONMENT SETUP GUIDE 🎬
###############################################################################
#
#  Welcome! Follow this guide to set up your own AniXo instance.
#
#  📋 QUICK START:
#  ──────────────
#  1. Copy this file → rename to ".env"
#  2. Fill in YOUR values (replace the placeholders)
#  3. Do the same for /backend-core/.env
#  4. Install dependencies & run!
#
#  ⚠️  NEVER commit your real .env file to GitHub!
#      This .env.example is safe — it has no real credentials.
#
###############################################################################
#                          📦 INSTALLATION
###############################################################################
#
#  Run these commands in separate terminals:
#
#  ┌──────────────────┬───────────────────┬──────────────────────┐
#  │ Service          │ Folder            │ Command              │
#  ├──────────────────┼───────────────────┼──────────────────────┤
#  │ Frontend         │ / (root)          │ npm install          │
#  │ Auth Backend     │ /backend-core     │ npm install          │
#  │ Allanime Scraper │ /Allanime-api     │ npm install          │
#  │ Python Scraper   │ /api              │ pip install -r ...   │
#  └──────────────────┴───────────────────┴──────────────────────┘
#
###############################################################################
#                           🚀 RUNNING LOCALLY
###############################################################################
#
#  ┌──────────────────┬───────────────────┬──────────────────────┐
#  │ Service          │ Folder            │ Command              │
#  ├──────────────────┼───────────────────┼──────────────────────┤
#  │ Frontend         │ / (root)          │ npm run dev          │
#  │ Auth Backend     │ /backend-core     │ npm start            │
#  │ Allanime API     │ /Allanime-api     │ npm start            │
#  │ Python Scraper   │ /api              │ python index.py      │
#  └──────────────────┴───────────────────┴──────────────────────┘
#
###############################################################################


# ═══════════════════════════════════════════════════════════════════════════════
# 1️⃣  FRONTEND SETTINGS (Vite / React)
# ═══════════════════════════════════════════════════════════════════════════════
# These are used by the frontend React app.
# Variables starting with VITE_ are exposed to the browser.

# AniList GraphQL API — Used for anime search & metadata.
# 👉 Free, no signup needed. Don't change this.
VITE_ANILIST_API=https://graphql.anilist.co

# Python Scraper API — Your Anikai scraper backend.
# 👉 Local: http://localhost:5000
# 👉 Production: Deploy /api folder to Render/Railway and paste URL here.
VITE_PYTHON_API=http://localhost:5000

# (Optional) Backup Python API — Used if primary goes down.
# 👉 Leave empty if you don't have a backup.
VITE_PYTHON_API_BACKUP=

# Allanime Scraper API — Your Allanime proxy.
# 👉 Local: http://localhost:5678
# 👉 Production: Deploy /Allanime-api to Cloudflare Workers and paste URL here.
VITE_ALLANIME_API=http://localhost:5678

# Auth Backend — Your Node.js backend (handles login, watchlist, comments).
# 👉 Local: http://localhost:5001
# 👉 Production: Deploy /backend-core to Render and paste URL here.
VITE_BACKEND_API=http://localhost:5001

# Miruro Worker — Cloudflare Worker for Server 6 streams.
# 👉 Deploy your own Miruro worker or use the public one.
# 👉 How: Fork miruro-api repo → Deploy to Cloudflare Workers → Paste URL.
VITE_MIRURO_API=https://your-miruro-worker.workers.dev

# Anigo Scraper — Hugging Face Space for Server 7 & 8 streams.
# 👉 Deploy your own HF Space or use an existing one.
# 👉 How: Create HF Space → Upload scraper code → Paste /api URL here.
VITE_ANIGO_HF_API=https://your-space-name.hf.space/api

# MegaPlay — Embed player URL for Server 3 (MAL) & Server 4 (AniList).
# 👉 This is a public embed service. Don't change unless it changes domain.
VITE_MEGAPLAY_URL=https://megaplay.buzz

# AniSkip API — Auto-fetches OP/ED skip times for episodes.
# 👉 Free, public API. No signup needed. Don't change this.
VITE_ANISKIP_API=https://api.aniskip.com/v2

# Jikan API — MAL metadata (episode titles, ratings).
# 👉 Free, public API. No signup needed. Don't change this.
VITE_JIKAN_API=https://api.jikan.moe/v4

# Your Website URL — Used for SEO meta tags, share links, and schema.org.
# 👉 Local: http://localhost:5173
# 👉 Production: Your domain (e.g., https://myanimelist.example.com)
VITE_SITE_URL=http://localhost:5173

# Cloudflare Turnstile (PUBLIC Site Key) — Anti-bot for login/register.
# 👉 Get yours: https://dash.cloudflare.com → Turnstile → Add Site
# 👉 Use the SITE KEY here (starts with 0x4...), NOT the secret key!
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here


# ═══════════════════════════════════════════════════════════════════════════════
# 2️⃣  BACKEND & DATABASE (backend-core/.env)
# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️  Copy these to /backend-core/.env as well!

# MongoDB Connection — Your database for users, watchlists, comments.
# 👉 Get free: https://www.mongodb.com/atlas → Create Cluster → Get Connection String
# 👉 Replace <username>, <password>, and <dbname> with your values.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Secret — Used to sign login tokens. Make it long and random!
# 👉 Generate: Run in terminal → node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=paste_your_random_64_char_string_here

# Backend Port — Where your auth server runs.
PORT=5001

# Frontend URL — Used for password reset email links.
# 👉 Local: http://localhost:5173
# 👉 Production: Your domain (same as VITE_SITE_URL)
FRONTEND_URL=http://localhost:5173

# Your production site URL — Used in email templates for logo.
SITE_URL=http://localhost:5173


# ═══════════════════════════════════════════════════════════════════════════════
# 3️⃣  EMAIL SERVICE (Password Reset Emails)
# ═══════════════════════════════════════════════════════════════════════════════
# Used by Nodemailer to send "Forgot Password" emails.

# Gmail SMTP — Don't change host/port unless using a different provider.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465

# Your Gmail address that will SEND the reset emails.
EMAIL_USER=your-email@gmail.com

# Gmail App Password (NOT your regular Gmail password!)
# 👉 How to get:
#    1. Go to https://myaccount.google.com/security
#    2. Enable 2-Step Verification
#    3. Go to "App Passwords" → Select "Mail" → Generate
#    4. Copy the 16-character password and paste here.
EMAIL_PASS=your_16_digit_app_password


# ═══════════════════════════════════════════════════════════════════════════════
# 4️⃣  SECURITY KEYS
# ═══════════════════════════════════════════════════════════════════════════════

# Cloudflare Turnstile (SECRET Key) — Backend verification for anti-bot.
# 👉 Get yours: https://dash.cloudflare.com → Turnstile → Your Site → Secret Key
# 👉 Use the SECRET KEY here, NOT the site key!
# ⚠️  NEVER expose this in frontend code!
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here


###############################################################################
#                        🗂️  QUICK REFERENCE
###############################################################################
#
#  Which .env goes where?
#
#  ┌────────────────────────┬───────────────────────────────────────┐
#  │ File Location          │ Variables Needed                      │
#  ├────────────────────────┼───────────────────────────────────────┤
#  │ /.env                  │ All VITE_* variables                  │
#  │ /backend-core/.env     │ MONGO_URI, JWT_SECRET, PORT,          │
#  │                        │ FRONTEND_URL, SITE_URL, EMAIL_*,      │
#  │                        │ TURNSTILE_SECRET_KEY                  │
#  └────────────────────────┴───────────────────────────────────────┘
#
#  🔒 SECURITY CHECKLIST:
#  ☐ .env is in .gitignore (NEVER push to GitHub!)
#  ☐ JWT_SECRET is a random 64+ char string
#  ☐ TURNSTILE_SECRET_KEY is not in frontend code
#  ☐ MongoDB password is strong
#  ☐ Gmail App Password (not regular password)
#
###############################################################################
#                         🎬 Happy Streaming! 🎬
###############################################################################
