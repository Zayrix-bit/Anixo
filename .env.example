###############################################################################
# ANIXO - ULTIMATE SETUP & CONFIGURATION GUIDE
###############################################################################
#
# This file serves as a template for your environment variables. 
# To get started:
# 1. Copy this file and rename it to ".env" in the following folders:
#    - Root Directory (for Frontend)
#    - /backend-core
#    - /Allanime-api
#
# 2. Fill in the required values as explained in the sections below.
#
###############################################################################
# STEP 1: INSTALLATION COMMANDS
###############################################################################
#
# Before running the servers, install dependencies in each directory:
#
# [Frontend - Root Folder]
# command: npm install
#
# [Main Backend - /backend-core Folder]
# command: npm install
#
# [Allanime Scraper - /Allanime-api Folder]
# command: npm install
#
# [Python Scraper - /api Folder]
# command: pip install -r requirements.txt
#
###############################################################################
# STEP 2: RUNNING THE SERVERS
###############################################################################
#
# To start everything locally, run these commands in separate terminals:
#
# Frontend:     npm run dev      (in root)
# Main Backend: npm start        (in /backend-core)
# Allanime API: npm start        (in /Allanime-api)
# Python API:   python index.py  (in /api)
#
###############################################################################
# ENVIRONMENT VARIABLES CONFIGURATION
###############################################################################

# =============================================================================
# 1. FRONTEND SETTINGS (Vite / React)
# =============================================================================

# (Required) The GraphQL endpoint for AniList. Used for metadata and search.
VITE_ANILIST_API=https://graphql.anilist.co

# (Required) Connection to your local or hosted Python Scraper.
# Default Local: http://localhost:5000
VITE_PYTHON_API=http://localhost:5000

# (Required) Connection to your local or hosted Allanime Scraper.
# Default Local: http://localhost:5678
VITE_ALLANIME_API=http://localhost:5678

# (Required) Connection to your main Auth/Database backend.
# Default Local: http://localhost:5001
VITE_BACKEND_API=http://localhost:5001

# (Required) Your Cloudflare Turnstile public site key for login protection.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAADGQxfMRQroxFG6O


# =============================================================================
# 2. BACKEND & DATABASE SETTINGS (backend-core)
# =============================================================================

# (Critical) Your MongoDB Atlas connection string.
# Necessary for user accounts, watchlists, and comments.
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/database_name

# (Critical) A secret string used to sign and verify JWT login tokens.
# Use a long, random string for production.
JWT_SECRET=your_random_secret_key_here

# (Required) The public URL of your website (used for password reset links).
# Local: http://localhost:5173 | Production: https://anixo.online
FRONTEND_URL=http://localhost:5173

# (Required) The port where backend-core will run.
PORT=5001


# =============================================================================
# 3. EMAIL SERVICE SETTINGS (Nodemailer)
# =============================================================================
# Used for sending Password Reset and Verification emails.

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465

# Your Gmail address used for sending emails.
EMAIL_USER=your-email@gmail.com

# Your Gmail 'App Password' (Not your regular login password).
# Generate this in Google Account Settings -> Security -> App Passwords.
EMAIL_PASS=your-16-digit-app-password


# =============================================================================
# 4. SECURITY & EXTRAS
# =============================================================================

# (Required) Cloudflare Turnstile Secret Key (Backend verification).
# Keep this secret and do not expose it to the frontend.
TURNSTILE_SECRET_KEY=0x4AAAAAADGQxcZgLa0ZRtaJbL3mxiKj4RA


###############################################################################
# END OF CONFIGURATION GUIDE
###############################################################################
