{
  "version": 2,
  "framework": "vite",
  "crons": [
    {
      "path": "/api/cron-cleanup",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/cron-cleanup",
      "destination": "/api/cron-cleanup.js"
    },
    {
      "source": "/api/auth/(.*)",
      "destination": "/api/user.mjs"
    },
    {
      "source": "/api/settings",
      "destination": "/api/user.mjs"
    },
    {
      "source": "/api/settings/(.*)",
      "destination": "/api/user.mjs"
    },
    {
      "source": "/api/watchlist",
      "destination": "/api/user.mjs"
    },
    {
      "source": "/api/watchlist/(.*)",
      "destination": "/api/user.mjs"
    },
    {
      "source": "/api/notifications",
      "destination": "/api/user.mjs"
    },
    {
      "source": "/api/notifications/(.*)",
      "destination": "/api/user.mjs"
    },
    {
      "source": "/api/progress",
      "destination": "/api/user.mjs"
    },
    {
      "source": "/api/progress/(.*)",
      "destination": "/api/user.mjs"
    },
    {
      "source": "/api/users",
      "destination": "/api/user.mjs"
    },
    {
      "source": "/api/users/(.*)",
      "destination": "/api/user.mjs"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/index.py"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
