{
  "version": 2,
  "framework": "vite",
  "crons": [
    {
      "path": "/api/cron-cleanup",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/cron-cleanup",
      "destination": "/api/cron-cleanup.js"
    },
    { "source": "/api/v1/auth", "destination": "/api/user.mjs" },
    { "source": "/api/v1/auth/(.*)", "destination": "/api/user.mjs" },
    { "source": "/api/v1/watchlist", "destination": "/api/user.mjs" },
    { "source": "/api/v1/watchlist/(.*)", "destination": "/api/user.mjs" },
    { "source": "/api/v1/progress", "destination": "/api/user.mjs" },
    { "source": "/api/v1/progress/(.*)", "destination": "/api/user.mjs" },
    { "source": "/api/v1/settings", "destination": "/api/user.mjs" },
    { "source": "/api/v1/settings/(.*)", "destination": "/api/user.mjs" },
    { "source": "/api/v1/notifications", "destination": "/api/user.mjs" },
    { "source": "/api/v1/notifications/(.*)", "destination": "/api/user.mjs" },
    { "source": "/api/v1/(.*)", "destination": "/api/user.mjs" },
    { "source": "/auth/(.*)", "destination": "/api/user.mjs" },
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/sitemap.xml", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
